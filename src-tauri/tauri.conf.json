{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.donkidunk.app",
  "version": "../package.json",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Donkidunk",
        "width": 1440,
        "height": 900,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "/**/*.mp4"
        ]
      },
      "csp": {
        "media-src": "'self' asset: http://asset.localhost blob: data:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "externalBin": [
      "./bin/donkidunk_ffmpeg"
    ]
  }
}