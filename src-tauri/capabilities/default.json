{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "opener:default",
    "sql:default",
    "sql:allow-execute",
    "log:default",
    "dialog:default",
    "os:default",
    "fs:default",
    "fs:allow-app-write-recursive",
    "fs:allow-truncate",
    {
      "identifier": "fs:allow-copy-file",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "**/*"
        }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        {
          "path": "$APPLOCALDATA/**"
        }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "./bin/donkidunk_ffmpeg",
          "sidecar": true
        }
      ]
    },
    "shell:allow-open",
    "deep-link:default",
    {
      "identifier": "http:default",
      "allow": [
        {
          "url": "https://*.donkidunk.com"
        }
      ]
    }
  ]
}